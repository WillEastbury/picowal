// WiFi configuration for PicoWAL
//
// Copy this file to wifi_config.h and fill in your credentials:
//   cp src/wifi_config.h.example src/wifi_config.h
//
// wifi_config.h is gitignored and will not be committed.
// If wifi_config.h is missing, the build uses dummy defaults
// that will not connect to any network.

#ifndef WIFI_CONFIG_H
#define WIFI_CONFIG_H

#define WIFI_SSID     "your_ssid_here"
#define WIFI_PASSWORD "your_password_here"

#endif
